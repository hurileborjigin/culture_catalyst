# Culture Catalyst - Environment Variables
# Copy this file to .env.local and fill in your API keys

# ============================================
# Supabase Configuration
# ============================================
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://whknqrpkiazvlubxonaf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# LLM Provider - Azure OpenAI
# ============================================
# Your Azure OpenAI deployment name (model)
SYNAPSE_LLM_MODEL=gpt-5.2

# Azure OpenAI API Key from Azure Portal
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Azure OpenAI Endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI API Version
AZURE_OPENAI_API_VERSION=2024-06-01

# ============================================
# Search APIs - Tavily
# ============================================
# Tavily API Key for web search (get at https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key
